# ==============================================
# 1. uni-app 核心忽略规则（必加）
# ==============================================
# uni-app插件市场安装的插件目录（绝对不要提交，可重新安装）
/uni_modules/
# 打包编译生成的目录（不要提交，每次打包都会重新生成）
/unpackage/
# HBuilderX/Trae编辑器本地配置（个人环境配置，不要提交）
.hbuilderx/
.idea/
.vscode/
*.swp
# Mac系统自动生成的隐藏文件（跨平台项目必加）
.DS_Store

# ==============================================
# 2. 依赖&临时文件（必加）
# ==============================================
# node_modules依赖目录（不要提交，队友可npm install安装）
/node_modules/
# 日志文件
*.log
npm-debug.log*
# 临时压缩包/备份文件（避免以后误传zip到仓库）
*.zip
*.rar
*.7z

# ==============================================
# 3. uniCloud 安全&冗余规则（必加！非常重要）
# ==============================================
# uniCloud云空间密钥文件（绝对禁止提交！泄露会导致云空间被盗）
serviceAccountKey.json
# 本地数据库查询脚本（仅本地调试用，不需要提交到仓库）
*.jql
# 云函数本地调试临时文件（可选，避免误传）
*.local
.env
.env.local